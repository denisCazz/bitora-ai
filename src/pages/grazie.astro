---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import Reveal from '../components/ui/Reveal.astro';
import ParticleField from '../components/three/ParticleField.astro';
---

<Layout
  title="Grazie — Richiesta inviata"
  description="Abbiamo ricevuto la tua richiesta di diagnosi AI gratuita. Ti risponderemo entro 24 ore."
  noindex={true}
>
  <Header />
  <main id="main">

  <section class="relative overflow-hidden py-24 sm:py-32">
    <div class="pointer-events-none absolute inset-0 bg-grid-pattern bg-grid opacity-[0.15]"></div>
    <ParticleField count={400} class="opacity-50" />
    <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-[600px] w-[900px] bg-aurora-gradient opacity-25 blur-4xl rounded-full"></div>

    <!-- Confetti -->
    <div class="confetti pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      {Array.from({ length: 36 }).map((_, i) => (
        <span
          class="confetti-piece"
          style={`
            --i:${i};
            --delay:${(i * 0.08).toFixed(2)}s;
            --duration:${(2.6 + (i % 5) * 0.4).toFixed(2)}s;
            --x:${((i * 137) % 100)}%;
            --rot:${(i * 27) % 360}deg;
            --color:${["#6366f1", "#22d3ee", "#a855f7", "#facc15", "#f472b6"][i % 5]};
          `}
        ></span>
      ))}
    </div>

    <div class="relative mx-auto max-w-3xl px-4 text-center">

      <Reveal>
        <div class="relative inline-flex items-center justify-center mb-8">
          <div class="absolute inset-0 rounded-full bg-brand-gradient blur-2xl opacity-60 animate-glow-pulse"></div>
          <div class="relative flex h-24 w-24 items-center justify-center rounded-full bg-brand-gradient shadow-glow-brand">
            <svg class="h-12 w-12 text-white check-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" pathLength="100" stroke-dasharray="100" stroke-dashoffset="100"/>
            </svg>
          </div>
        </div>
      </Reveal>

      <Reveal delay={150}>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-white leading-tight mb-5">
          Richiesta inviata!<br />
          <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">Ti risponderemo a breve.</span>
        </h1>
      </Reveal>

      <Reveal delay={300}>
        <p class="text-lg text-slate-400 mb-12 leading-relaxed max-w-xl mx-auto">
          Abbiamo ricevuto la tua richiesta di diagnosi AI gratuita.
          Ti risponderemo entro 24 ore per fissare la sessione.
        </p>
      </Reveal>

      <Reveal delay={450}>
        <div class="relative rounded-3xl border border-white/10 bg-surface-800/60 backdrop-blur-md p-8 md:p-10 mb-10 text-left overflow-hidden">
          <div class="pointer-events-none absolute -top-20 -right-20 h-[200px] w-[200px] rounded-full bg-brand-500/10 blur-3xl"></div>
          <h2 class="relative text-lg font-bold text-white mb-7 font-display flex items-center gap-2">
            <Icon name="sparkles" class="h-5 w-5 text-accent-400" />
            Cosa succede adesso
          </h2>
          <ol class="relative space-y-6">
            {[
              { icon: "mail", step: "Entro 24 ore", desc: "Riceverai una email di conferma con le istruzioni per fissare la call." },
              { icon: "calendar", step: "Fissiamo la diagnosi", desc: "30 minuti in video call o dal vivo a Carmagnola. Scegli tu quando." },
              { icon: "rocket", step: "Piano su misura", desc: "Ti diciamo da dove partire e quanto puoi ottenere. Nessun impegno." },
            ].map((s, i) => (
              <li class="flex gap-4">
                <div class="relative flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/15 text-brand-300 border border-brand-500/30">
                  <Icon name={s.icon} class="h-4 w-4" />
                  <span class="absolute -top-1.5 -right-1.5 flex h-5 w-5 items-center justify-center rounded-full bg-brand-gradient text-[10px] font-bold text-white">{i + 1}</span>
                </div>
                <div class="pt-1">
                  <div class="text-sm font-semibold text-white">{s.step}</div>
                  <div class="text-sm text-slate-400 leading-relaxed mt-0.5">{s.desc}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </Reveal>

      <Reveal delay={600}>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <Button href="/" variant="secondary" size="md">
            <Icon name="arrow" class="h-3.5 w-3.5 rotate-180" />
            Torna alla home
          </Button>
          <Button href="/casi-studio" variant="primary" size="md">
            Esplora i casi studio
            <Icon name="arrow" class="h-3.5 w-3.5" />
          </Button>
        </div>
      </Reveal>

    </div>
  </section>

  </main>
  <Footer />
</Layout>

<style>
  .check-svg polyline {
    animation: drawCheck 0.7s ease-out 0.4s forwards;
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  .confetti-piece {
    position: absolute;
    top: -10px;
    left: var(--x);
    width: 10px;
    height: 14px;
    background: var(--color);
    transform: rotate(var(--rot));
    border-radius: 2px;
    opacity: 0;
    animation: fall var(--duration) cubic-bezier(0.32, 0.72, 0.4, 1) var(--delay) forwards;
  }
  @keyframes fall {
    0% { opacity: 0; transform: translateY(-20px) rotate(var(--rot)) scale(0.8); }
    10% { opacity: 1; }
    100% { opacity: 0; transform: translateY(110vh) rotate(calc(var(--rot) + 720deg)) scale(1.1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .confetti-piece { display: none; }
    .check-svg polyline { stroke-dashoffset: 0 !important; animation: none; }
  }
</style>
