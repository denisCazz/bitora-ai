---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Heading from '../components/ui/Heading.astro';
import Icon from '../components/ui/Icon.astro';
import Reveal from '../components/ui/Reveal.astro';
import ParticleField from '../components/three/ParticleField.astro';

const features = [
  { icon: "brain", title: "Addestrato sui tuoi dati", desc: "Carica FAQ, listini, manuali, procedure. Il chatbot risponde solo con le tue informazioni, senza inventare." },
  { icon: "message", title: "Sito + WhatsApp + Telegram", desc: "Un sistema centralizzato su tutti i canali, tutte le conversazioni in una sola dashboard." },
  { icon: "workflow", title: "Passaggio operatore", desc: "Quando la richiesta è complessa, il bot passa la conversazione con tutto il contesto: nessuna info persa." },
  { icon: "clock", title: "Attivo 24/7", desc: "Risponde fuori orario, weekend, di notte. Le richieste fuori orario non vanno più perse." },
  { icon: "shield", title: "GDPR e dati isolati", desc: "I dati del cliente non vengono usati per addestrare modelli esterni. Hosting italiano disponibile." },
  { icon: "bar", title: "Analytics conversazioni", desc: "Domande più frequenti, argomenti irrisolti e opportunità per migliorare il bot nel tempo." },
];

const sectors = [
  { sector: "Ristoranti e Bar", examples: ["Orari e prenotazioni automatiche", "Menù e disponibilità", "Gestione eventi e gruppi"] },
  { sector: "Studi e Consulenza", examples: ["Qualificazione lead iniziale", "Fissare appuntamenti", "FAQ servizi e tariffe"] },
  { sector: "E-commerce e Retail", examples: ["Stato ordini e resi", "Disponibilità prodotti", "Supporto post-acquisto"] },
  { sector: "B2B e Servizi", examples: ["Richieste di preventivo", "Documentazione tecnica", "Ticket primo livello"] },
];
---

<Layout
  title="Chatbot AI Aziendale"
  description="Chatbot AI per sito web e WhatsApp addestrato sui tuoi dati. Risponde H24, gestisce il 70% delle richieste automaticamente, passa all'operatore quando serve."
>
  <Header />
  <main id="main">

  <!-- HERO -->
  <section class="relative overflow-hidden pt-12 pb-24 sm:pt-16">
    <div class="pointer-events-none absolute inset-0 bg-grid-pattern bg-grid opacity-[0.15] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000,transparent_70%)]"></div>
    <ParticleField count={350} class="opacity-40" />
    <div class="pointer-events-none absolute -top-40 left-1/3 h-[500px] w-[700px] bg-brand-500/15 blur-4xl rounded-full"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <Reveal class="inline-flex">
          <Badge variant="brand">
            <Icon name="bot" class="h-3 w-3" />
            Chatbot AI Aziendale
          </Badge>
        </Reveal>
        <Reveal delay={120}>
          <h1 class="mt-5 font-display text-4xl sm:text-5xl lg:text-[3.5rem] font-bold text-white leading-[1.05]">
            Il tuo assistente AI<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">attivo H24.</span>
          </h1>
        </Reveal>
        <Reveal delay={250}>
          <p class="mt-6 text-lg text-slate-400 leading-relaxed">
            Un chatbot addestrato sui tuoi documenti, listini e procedure. Risponde in italiano naturale
            su sito web e WhatsApp, gestisce il <strong class="text-white">70% delle richieste</strong> autonomamente
            e passa all'operatore solo quando serve.
          </p>
        </Reveal>
        <Reveal delay={400}>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="/contatti?interesse=Chatbot+Aziendale" variant="primary" size="lg">
              Richiedi demo gratuita
              <Icon name="arrow" class="h-4 w-4" />
            </Button>
            <Button href="#chat-demo" variant="secondary" size="lg">Vedi conversazione</Button>
          </div>
        </Reveal>
        <Reveal delay={550}>
          <div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-xs text-slate-400">
            {["Attivo in 2-4 settimane", "Dati isolati per cliente", "Hosting italiano", "GDPR compliant"].map((b) => (
              <span class="flex items-center gap-1.5">
                <Icon name="check" class="h-3.5 w-3.5 text-accent-400" />
                {b}
              </span>
            ))}
          </div>
        </Reveal>
      </div>

      <!-- Animated chat mockup -->
      <Reveal delay={200}>
        <div id="chat-demo" class="relative">
          <!-- Glow halo -->
          <div class="absolute -inset-6 bg-aurora-gradient opacity-20 blur-4xl rounded-[2.5rem]"></div>

          <div class="chatbot-mockup relative rounded-3xl border border-white/10 bg-surface-800/90 backdrop-blur-xl p-2 shadow-2xl shadow-brand-600/20 transform-gpu overflow-hidden">
            <div class="rounded-2xl bg-surface-700/80 overflow-hidden">
              <!-- Chat header -->
              <div class="flex items-center gap-3 p-4 border-b border-white/5 bg-surface-800/80">
                <div class="relative h-9 w-9 rounded-full bg-brand-gradient flex items-center justify-center text-xs font-bold text-white shrink-0">
                  AI
                  <span class="absolute -right-0.5 -bottom-0.5 h-3 w-3 rounded-full bg-green-400 border-2 border-surface-800 animate-pulse"></span>
                </div>
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-white">Assistente Alfa Impianti</div>
                  <div class="flex items-center gap-1.5 text-[10px] text-slate-400 font-mono">
                    <span class="h-1 w-1 rounded-full bg-green-400"></span>
                    Online · addestrato sui vostri dati
                  </div>
                </div>
                <div class="ml-auto flex gap-1 shrink-0">
                  <span class="h-2 w-2 rounded-full bg-red-500/60"></span>
                  <span class="h-2 w-2 rounded-full bg-yellow-500/60"></span>
                  <span class="h-2 w-2 rounded-full bg-green-500/60"></span>
                </div>
              </div>

              <!-- Messages -->
              <div class="p-4 space-y-3 min-h-[340px]">

                <!-- Msg 1: utente -->
                <div class="chat-msg flex justify-start" style="animation-delay:0.4s">
                  <div class="rounded-2xl rounded-tl-sm bg-surface-600/80 px-4 py-2.5 max-w-[82%]">
                    <p class="text-sm text-white">Buongiorno, vi contatto per un guasto alla caldaia industriale modello TC-420. Siete convenzionati Thermotech?</p>
                  </div>
                </div>

                <!-- Typing 1 -->
                <div class="chat-msg flex justify-end" style="animation-delay:1.2s">
                  <div class="rounded-2xl rounded-tr-sm bg-surface-700/60 px-4 py-3 flex gap-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-slate-400 typing-dot" style="animation-delay:0s"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-slate-400 typing-dot" style="animation-delay:0.15s"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-slate-400 typing-dot" style="animation-delay:0.3s"></span>
                  </div>
                </div>

                <!-- Msg 2: AI -->
                <div class="chat-msg flex justify-end" style="animation-delay:2.5s">
                  <div class="rounded-2xl rounded-tr-sm bg-brand-gradient px-4 py-2.5 max-w-[82%] shadow-glow-soft">
                    <p class="text-sm text-white">Buongiorno! Sì, siamo centro assistenza autorizzato Thermotech. Per il TC-420 abbiamo tecnici disponibili. Può dirmi il codice errore sul display?</p>
                  </div>
                </div>

                <!-- Msg 3: utente -->
                <div class="chat-msg flex justify-start" style="animation-delay:3.6s">
                  <div class="rounded-2xl rounded-tl-sm bg-surface-600/80 px-4 py-2.5 max-w-[82%]">
                    <p class="text-sm text-white">E3-44, e la pressione scende sotto 0.8 bar.</p>
                  </div>
                </div>

                <!-- Typing 2 -->
                <div class="chat-msg flex justify-end" style="animation-delay:4.3s">
                  <div class="rounded-2xl rounded-tr-sm bg-surface-700/60 px-4 py-3 flex gap-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-slate-400 typing-dot" style="animation-delay:0s"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-slate-400 typing-dot" style="animation-delay:0.15s"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-slate-400 typing-dot" style="animation-delay:0.3s"></span>
                  </div>
                </div>

                <!-- Msg 4: AI con chip -->
                <div class="chat-msg flex justify-end" style="animation-delay:5.5s">
                  <div class="rounded-2xl rounded-tr-sm bg-brand-gradient px-4 py-2.5 max-w-[82%] shadow-glow-soft space-y-1.5">
                    <p class="text-sm text-white">Codice E3-44 = perdita di carico nel circuito primario. Di solito è valvola di sfiato o vaso d'espansione. Intervento stimato: 1–2h.</p>
                    <div class="flex gap-1.5 flex-wrap pt-0.5">
                      <span class="inline-flex items-center gap-1 rounded-full bg-white/15 px-2.5 py-0.5 text-[10px] text-white/90 font-medium">
                        <span class="h-1 w-1 rounded-full bg-green-300"></span>
                        Urgente disponibile domani 8:00
                      </span>
                    </div>
                    <p class="text-sm text-white">Vuole prenotare il tecnico o preferisce parlare con lo staff?</p>
                  </div>
                </div>

              </div>

              <!-- Input bar -->
              <div class="p-3 border-t border-white/5 flex items-center gap-2">
                <div class="flex-1 rounded-xl bg-white/5 px-4 py-2.5 text-xs text-slate-500 italic">Scrivi un messaggio…</div>
                <div class="h-9 w-9 rounded-xl bg-brand-gradient flex items-center justify-center text-white shrink-0">
                  <Icon name="arrow" class="h-4 w-4" />
                </div>
              </div>
            </div>
          </div>

          <!-- Floating chips -->
          <div class="hidden md:block absolute -top-3 -right-3 rotate-2">
            <div class="flex items-center gap-2 rounded-xl border border-green-400/30 bg-green-400/10 backdrop-blur-md px-3 py-2 shadow-lg">
              <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span>
              <span class="text-[11px] text-green-300 font-medium">71% richieste risolte in autonomia</span>
            </div>
          </div>
          <div class="hidden md:block absolute -bottom-4 -left-4 -rotate-2">
            <div class="flex items-center gap-2 rounded-xl border border-brand-400/30 bg-brand-400/10 backdrop-blur-md px-3 py-2 shadow-lg">
              <Icon name="clock" class="h-3 w-3 text-brand-300" />
              <span class="text-[11px] text-brand-200 font-medium">Risposta media: 1.8s</span>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <style>
    .chat-msg {
      opacity: 0;
      transform: translateY(8px);
      animation: chatIn 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards;
    }
    @keyframes chatIn {
      to { opacity: 1; transform: translateY(0); }
    }
    .typing-dot {
      animation: typing 1.2s infinite;
    }
    @keyframes typing {
      0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
      30% { transform: translateY(-3px); opacity: 1; }
    }
    @media (min-width: 768px) {
      .chatbot-mockup {
        transform: perspective(1400px) rotateY(-6deg) rotateX(2deg);
      }
    }
  </style>

  <!-- FEATURES -->
  <Section variant="glow" padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Come funziona" level={2} highlight="Bitora AI">
          Il chatbot
        </Heading>
      </Reveal>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <Reveal delay={i * 80}>
          <div class="group relative rounded-2xl border border-white/5 bg-surface-800/80 backdrop-blur-sm p-6 hover:border-brand-500/30 transition-all hover:-translate-y-1 duration-300 h-full">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/10 text-brand-300 mb-5 group-hover:bg-brand-500/20 transition-colors">
              <Icon name={f.icon} class="h-5 w-5" />
            </div>
            <h3 class="text-base font-semibold text-white mb-2 font-display">{f.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{f.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- SECTORS -->
  <Section variant="dark" padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Per ogni settore" level={2}>
          Per quali aziende è adatto
        </Heading>
      </Reveal>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {sectors.map((s, i) => (
        <Reveal delay={i * 80}>
          <div class="rounded-2xl border border-white/5 bg-surface-800/80 backdrop-blur-sm p-6 hover:border-brand-500/30 transition-colors h-full">
            <h3 class="text-sm font-semibold text-white mb-4 font-display">{s.sector}</h3>
            <ul class="space-y-2">
              {s.examples.map((e) => (
                <li class="flex items-start gap-2 text-xs text-slate-400">
                  <span class="text-brand-300 mt-0.5">›</span>
                  <span>{e}</span>
                </li>
              ))}
            </ul>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- STATS -->
  <Section padding="lg">
    <div class="grid sm:grid-cols-3 gap-5 max-w-4xl mx-auto">
      {[
        { v: "70%", l: "richieste gestite autonomamente" },
        { v: "95%", l: "tasso risoluzione in produzione" },
        { v: "H24", l: "anche di notte, weekend e festivi" },
      ].map((s, i) => (
        <Reveal delay={i * 100}>
          <div class="rounded-2xl border border-white/10 bg-surface-800/60 backdrop-blur-md p-6 text-center hover:border-brand-500/30 transition-colors h-full">
            <div class="font-display text-4xl font-bold bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora mb-2">{s.v}</div>
            <div class="text-xs text-slate-400 leading-snug">{s.l}</div>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section padding="xl" border={false}>
    <Reveal>
      <div class="relative overflow-hidden rounded-3xl border border-brand-500/30 bg-surface-800/40 backdrop-blur-md p-10 md:p-16 text-center">
        <div class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 h-[400px] w-[700px] bg-aurora-gradient opacity-25 blur-4xl rounded-full"></div>
        <div class="relative">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">Vuoi vedere un chatbot<br />addestrato sui tuoi documenti?</h2>
          <p class="text-slate-400 mb-8 max-w-xl mx-auto">Nella diagnosi gratuita ti mostriamo un prototipo con i tuoi contenuti. Zero costi, zero impegni.</p>
          <Button href="/contatti?interesse=Chatbot+Aziendale" variant="primary" size="lg">
            Richiedi demo chatbot
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
        </div>
      </div>
    </Reveal>
  </Section>

  </main>
  <Footer />
</Layout>
