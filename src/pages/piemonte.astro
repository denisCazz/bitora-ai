---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Heading from '../components/ui/Heading.astro';
import Icon from '../components/ui/Icon.astro';
import Reveal from '../components/ui/Reveal.astro';

const cities = [
  { name: "Torino", x: 38, y: 52, big: true },
  { name: "Carmagnola", x: 41, y: 64, hq: true },
  { name: "Cuneo", x: 32, y: 80 },
  { name: "Asti", x: 55, y: 68 },
  { name: "Alba", x: 47, y: 73 },
  { name: "Pinerolo", x: 28, y: 60 },
  { name: "Alessandria", x: 67, y: 64 },
  { name: "Biella", x: 46, y: 38 },
  { name: "Vercelli", x: 56, y: 50 },
  { name: "Novara", x: 64, y: 42 },
];
---

<Layout
  title="AI per Aziende in Piemonte"
  description="Bitora AI: chatbot, automazioni e gestionali AI per le PMI del Piemonte. Sede a Carmagnola (TO). Diagnosi gratuita, risultati in 2-4 settimane."
>
  <Header />
  <main id="main">

  <!-- HERO + MAP -->
  <section class="relative overflow-hidden pt-12 pb-20 sm:pt-16">
    <div class="pointer-events-none absolute inset-0 bg-grid-pattern bg-grid opacity-[0.15] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000,transparent_70%)]"></div>
    <div class="pointer-events-none absolute -top-40 right-1/4 h-[500px] w-[700px] bg-brand-500/15 blur-4xl rounded-full"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <Reveal class="inline-flex">
          <Badge variant="brand">
            <Icon name="map-pin" class="h-3 w-3" />
            Piemonte · Sede a Carmagnola (TO)
          </Badge>
        </Reveal>
        <Reveal delay={120}>
          <h1 class="mt-6 font-display text-4xl sm:text-5xl lg:text-[3.5rem] font-bold text-white leading-[1.05]">
            AI operativa per<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">le aziende del Piemonte.</span>
          </h1>
        </Reveal>
        <Reveal delay={250}>
          <p class="mt-6 text-lg text-slate-400 leading-relaxed">
            Sede a Carmagnola, serviamo PMI, artigiani e aziende in tutto il Piemonte: Torino, Cuneo, Asti,
            Alba, Pinerolo, Alessandria, Biella e dintorni. <strong class="text-white">Supporto locale, nessun call center.</strong>
          </p>
        </Reveal>
        <Reveal delay={400}>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="/contatti" variant="primary" size="lg">
              Diagnosi AI gratuita
              <Icon name="arrow" class="h-4 w-4" />
            </Button>
            <Button href="https://wa.me/393514979670" variant="secondary" size="lg" external>
              <Icon name="whatsapp" class="h-4 w-4 text-green-400" />
              WhatsApp diretto
            </Button>
          </div>
        </Reveal>
      </div>

      <!-- Stylized Piemonte map -->
      <Reveal delay={200}>
        <div class="relative aspect-square">
          <div class="absolute -inset-6 bg-aurora-gradient opacity-20 blur-4xl rounded-full"></div>
          <div class="relative h-full rounded-3xl border border-white/10 bg-surface-800/60 backdrop-blur-md p-6 sm:p-8">
            <div class="absolute top-4 left-4 text-[10px] font-mono uppercase tracking-widest text-slate-500">
              piemonte · regione
            </div>
            <div class="absolute top-4 right-4 flex items-center gap-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span>
              <span class="text-[10px] font-mono text-slate-400">attivi · {cities.length} città</span>
            </div>

            <svg class="w-full h-full" viewBox="0 0 100 100" aria-hidden="true">
              <defs>
                <radialGradient id="pieGrad" cx="50%" cy="50%">
                  <stop offset="0%" stop-color="#6366f1" stop-opacity="0.18"/>
                  <stop offset="100%" stop-color="#6366f1" stop-opacity="0"/>
                </radialGradient>
                <linearGradient id="pieStroke" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#6366f1"/>
                  <stop offset="100%" stop-color="#22d3ee"/>
                </linearGradient>
              </defs>

              <!-- Stylized Piemonte outline -->
              <path
                d="M 28 22 Q 18 26 18 38 Q 14 46 18 56 Q 22 64 28 70 Q 30 80 38 86 Q 50 90 60 86 Q 72 82 76 70 Q 82 60 78 50 Q 80 38 74 30 Q 66 24 56 22 Q 42 20 28 22 Z"
                fill="url(#pieGrad)"
                stroke="url(#pieStroke)"
                stroke-width="0.6"
                stroke-linejoin="round"
              />
              <!-- Animated network lines from Carmagnola -->
              {cities.filter((c) => !c.hq).map((c) => (
                <line
                  x1={41} y1={64}
                  x2={c.x} y2={c.y}
                  stroke="url(#pieStroke)"
                  stroke-width="0.3"
                  opacity="0.6"
                  stroke-dasharray="2 2"
                  pathLength="100"
                >
                  <animate attributeName="stroke-dashoffset" from="100" to="0" dur="3s" repeatCount="indefinite"/>
                </line>
              ))}
              <!-- Cities -->
              {cities.map((c) => (
                <g transform={`translate(${c.x}, ${c.y})`}>
                  {c.hq && (
                    <>
                      <circle r="3.5" fill="#6366f1" opacity="0.3">
                        <animate attributeName="r" values="3.5;5;3.5" dur="2.4s" repeatCount="indefinite"/>
                        <animate attributeName="opacity" values="0.3;0;0.3" dur="2.4s" repeatCount="indefinite"/>
                      </circle>
                      <circle r="2.4" fill="#6366f1"/>
                      <circle r="1" fill="#fff"/>
                    </>
                  )}
                  {c.big && !c.hq && <circle r="2" fill="#22d3ee"/>}
                  {!c.big && !c.hq && <circle r="1.4" fill="#a5b4fc" opacity="0.8"/>}
                </g>
              ))}
              <!-- Labels (rendered as foreignObject would be heavy → use <text>) -->
              {cities.map((c) => (
                <text
                  x={c.x}
                  y={c.y - 4}
                  text-anchor="middle"
                  font-size={c.hq ? '3' : '2.4'}
                  fill={c.hq ? '#fff' : '#94a3b8'}
                  font-weight={c.hq ? 'bold' : 'normal'}
                  style="font-family: 'Inter', sans-serif"
                >{c.name}</text>
              ))}
            </svg>

            <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between">
              <div class="flex items-center gap-2 text-[10px] text-slate-400 font-mono">
                <span class="h-2 w-2 rounded-full bg-brand-400"></span> HQ
                <span class="h-2 w-2 rounded-full bg-accent-400 ml-2"></span> Major
              </div>
              <div class="text-[10px] font-mono text-brand-300">› Carmagnola</div>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- INCENTIVI -->
  <Section variant="dark" padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Incentivi PMI" level={2} highlight="del Piemonte">
          Bandi e contributi per le aziende
        </Heading>
      </Reveal>
    </div>

    <div class="grid sm:grid-cols-3 gap-5">
      {[
        { name: "AI Match Torino", body: "Camera di Commercio di Torino + AI4I: voucher fino a €15.000 per PMI della provincia di Torino. Previsto 2026.", tag: "Fino a €15.000" },
        { name: "Bandi Camerali", body: "Camera di Commercio Piemonte: fino al 50% a fondo perduto per progetti AI e cybersecurity. Importo max €5.000.", tag: "50% a fondo perduto" },
        { name: "Transizione 5.0", body: "Credito d'imposta fino al 45% per investimenti in software AI e automazioni. Valido per tutte le imprese italiane.", tag: "Fino al 45%" },
      ].map((i, idx) => (
        <Reveal delay={idx * 100}>
          <div class="relative rounded-2xl border border-brand-500/20 bg-surface-800/60 backdrop-blur-md p-6 hover:border-brand-500/40 transition-all hover:-translate-y-1 duration-300 h-full overflow-hidden">
            <div class="pointer-events-none absolute -top-10 -right-10 h-[150px] w-[150px] rounded-full bg-brand-500/10 blur-3xl"></div>
            <div class="relative">
              <div class="inline-flex items-center gap-1.5 rounded-full bg-aurora-gradient bg-[length:200%_200%] animate-aurora px-3 py-1 text-[11px] font-bold text-white mb-4">
                {i.tag}
              </div>
              <h3 class="text-base font-semibold text-white mb-2 font-display">{i.name}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{i.body}</p>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
    <p class="mt-8 text-center text-xs text-slate-500 max-w-2xl mx-auto">
      L'accesso ai bandi dipende da requisiti specifici. Verifichiamo insieme la compatibilità durante la diagnosi gratuita.
    </p>
  </Section>

  <!-- SECTORS -->
  <Section padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Per chi" level={2}>
          Chi serviamo in Piemonte
        </Heading>
      </Reveal>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { icon: "🏭", sector: "Manifattura", desc: "Ordini, manutenzione, documentazione tecnica automatizzati" },
        { icon: "🍽️", sector: "Ristorazione", desc: "Chatbot prenotazioni, risposta WhatsApp H24" },
        { icon: "📋", sector: "Studi professionali", desc: "Preventivi automatici, CRM intelligente, follow-up" },
        { icon: "🛒", sector: "Retail e Commercio", desc: "Supporto clienti automatizzato, gestione richieste" },
      ].map((s, i) => (
        <Reveal delay={i * 80}>
          <div class="group rounded-2xl border border-white/5 bg-surface-800/80 backdrop-blur-sm p-6 hover:border-brand-500/30 transition-all hover:-translate-y-1 duration-300 h-full">
            <div class="text-3xl mb-4">{s.icon}</div>
            <h3 class="text-base font-semibold text-white mb-2 font-display">{s.sector}</h3>
            <p class="text-xs text-slate-400 leading-relaxed">{s.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section padding="xl" border={false}>
    <Reveal>
      <div class="relative overflow-hidden rounded-3xl border border-brand-500/30 bg-surface-800/40 backdrop-blur-md p-10 md:p-16 text-center">
        <div class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 h-[400px] w-[700px] bg-aurora-gradient opacity-25 blur-4xl rounded-full"></div>
        <div class="relative">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
            Sei in Piemonte?<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">Parliamoci di persona.</span>
          </h2>
          <p class="text-slate-400 mb-8 max-w-xl mx-auto">
            Sede a Carmagnola. Disponibili per incontri dal vivo o video call. La diagnosi è sempre gratuita e senza impegno.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <Button href="/contatti" variant="primary" size="lg">Prenota diagnosi<Icon name="arrow" class="h-4 w-4" /></Button>
            <Button href="https://wa.me/393514979670" variant="secondary" size="lg" external>
              <Icon name="whatsapp" class="h-4 w-4 text-green-400" />
              WhatsApp diretto
            </Button>
          </div>
        </div>
      </div>
    </Reveal>
  </Section>

  </main>
  <Footer />
</Layout>
