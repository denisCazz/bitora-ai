---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Heading from '../components/ui/Heading.astro';
import Icon from '../components/ui/Icon.astro';
import Reveal from '../components/ui/Reveal.astro';

const programs = [
  {
    id: "ai-foundations",
    name: "AI Foundations",
    target: "Imprenditori e manager",
    duration: "4 ore",
    format: "Workshop in presenza o videoconferenza",
    topics: [
      "Cos'è davvero l'AI e cosa non è",
      "Opportunità e rischi reali per le PMI",
      "Casi d'uso pratici nel tuo settore",
      "Come valutare un progetto AI: costi e ROI",
      "GDPR e AI: cosa devi sapere",
    ],
    cta: "Organizza il workshop"
  },
  {
    id: "ai-team",
    name: "AI per il Team Operativo",
    target: "Collaboratori e staff",
    duration: "6 ore (2 sessioni da 3h)",
    format: "Laboratorio pratico con casi reali",
    topics: [
      "Strumenti AI per la produttività quotidiana",
      "Prompt engineering per il lavoro di ufficio",
      "Automazioni base con Make/Zapier",
      "ChatGPT, Copilot e strumenti verticali",
      "Come verificare e correggere l'output AI",
    ],
    cta: "Forma il team"
  },
];
---

<Layout
  title="Formazione e Transizione AI"
  description="Workshop e formazione AI per PMI italiane. Da Carmagnola a tutta Italia: imprenditori, manager e team operativo pronti a usare l'AI concretamente."
>
  <Header />
  <main id="main">

  <!-- HERO -->
  <section class="relative overflow-hidden pt-12 pb-24 sm:pt-16">
    <div class="pointer-events-none absolute inset-0 bg-grid-pattern bg-grid opacity-[0.15] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000,transparent_70%)]"></div>
    <div class="pointer-events-none absolute -top-40 left-1/4 h-[500px] w-[700px] bg-electric-400/10 blur-4xl rounded-full"></div>

    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <Reveal class="inline-flex">
        <Badge variant="electric">
          <Icon name="graduation-cap" class="h-3 w-3" />
          Formazione e Transizione AI
        </Badge>
      </Reveal>
      <Reveal delay={120}>
        <h1 class="mt-6 font-display text-4xl sm:text-5xl lg:text-[4rem] font-bold text-white leading-[1.05]">
          Il tuo team pronto<br />
          <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">a usare l'AI davvero.</span>
        </h1>
      </Reveal>
      <Reveal delay={250}>
        <p class="mt-7 text-lg text-slate-400 leading-relaxed max-w-2xl mx-auto">
          Senza formazione, i migliori sistemi AI restano inutilizzati. Formiamo imprenditori e collaboratori
          con workshop pratici, partendo da casi reali del loro settore.
        </p>
      </Reveal>
      <Reveal delay={400}>
        <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button href="/contatti?interesse=Formazione+AI" variant="primary" size="lg">
            Organizza un workshop
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
          <Button href="#transition-pack" variant="secondary" size="lg">AI Transition Pack</Button>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- PROGRAMS -->
  <Section variant="glow" padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Programmi" level={2} highlight="su misura">
          Formazione AI
        </Heading>
      </Reveal>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      {programs.map((p, i) => (
        <Reveal delay={i * 140}>
          <div class="group relative rounded-2xl border border-white/5 bg-surface-800/80 backdrop-blur-sm p-8 hover:border-brand-500/30 transition-all hover:-translate-y-1 duration-300 h-full overflow-hidden">
            <div class="pointer-events-none absolute -top-20 -right-20 h-[200px] w-[200px] rounded-full bg-brand-500/10 blur-3xl group-hover:bg-brand-500/20 transition-colors"></div>
            <div class="relative">
              <div class="flex items-start justify-between mb-6 gap-4">
                <div>
                  <Badge variant="brand" dot={false} class="mb-3">{p.target}</Badge>
                  <h3 class="text-2xl font-bold text-white font-display">{p.name}</h3>
                </div>
                <div class="text-right shrink-0">
                  <div class="font-mono text-xs uppercase tracking-widest text-accent-400">{p.duration}</div>
                  <div class="text-[10px] text-slate-500 mt-1 max-w-[180px]">{p.format}</div>
                </div>
              </div>
              <ul class="space-y-2.5 mb-7">
                {p.topics.map((t) => (
                  <li class="flex items-start gap-2.5 text-sm text-slate-300">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-md bg-accent-500/15 text-accent-300 mt-0.5">
                      <Icon name="check" class="h-3 w-3" />
                    </span>
                    {t}
                  </li>
                ))}
              </ul>
              <Button href={`/contatti?interesse=Formazione+AI&programma=${encodeURIComponent(p.name)}`} variant="outline" size="md">
                {p.cta}
                <Icon name="arrow" class="h-3.5 w-3.5" />
              </Button>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- TRANSITION PACK -->
  <Section id="transition-pack" variant="dark" padding="xl">
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <Reveal>
        <Badge variant="accent">AI Transition Pack</Badge>
        <h2 class="mt-5 font-display text-3xl sm:text-4xl font-bold text-white leading-tight">
          Per chi parte<br />
          <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">da zero.</span>
        </h2>
        <p class="mt-5 text-slate-400 leading-relaxed">
          Un percorso completo per le aziende che vogliono capire, pianificare e partire con l'AI
          senza bruciare budget su esperimenti sbagliati.
        </p>

        <div class="mt-8 space-y-3">
          {[
            { t: "AI Audit aziendale", d: "Mappiamo processi, sistemi e opportunità. Output: mappa delle priorità AI." },
            { t: "Roadmap personalizzata", d: "Piano 90 giorni con priorità, costi indicativi e KPI attesi." },
            { t: "Workshop di introduzione", d: "Sessione pratica di 4 ore per imprenditore e team chiave." },
            { t: "Progetto pilota", d: "Una prima automazione o chatbot in produzione e misurata." },
          ].map((s, i) => (
            <Reveal delay={i * 80}>
              <div class="flex gap-4 rounded-xl border border-white/5 bg-surface-800/60 backdrop-blur-sm p-4 hover:border-brand-500/30 transition-colors">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-gradient text-xs font-bold text-white shadow-glow-soft">{i + 1}</div>
                <div>
                  <div class="text-sm font-semibold text-white font-display">{s.t}</div>
                  <div class="text-xs text-slate-400 mt-0.5 leading-relaxed">{s.d}</div>
                </div>
              </div>
            </Reveal>
          ))}
        </div>

        <div class="mt-8">
          <Button href="/contatti?pack=start" variant="primary" size="lg">
            Inizia con AI Transition Pack
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
        </div>
      </Reveal>

      <Reveal delay={200}>
        <div class="sticky top-24 rounded-2xl border border-white/10 bg-surface-800/60 backdrop-blur-md p-7">
          <h3 class="text-lg font-bold text-white mb-5 font-display flex items-center gap-2">
            <span class="text-2xl">✓</span> Adatto se:
          </h3>
          <ul class="space-y-3">
            {[
              "Non sai da dove iniziare con l'AI",
              "Hai sentito parlare di AI ma non sai cosa fare",
              "Vuoi capire quanto costa davvero integrare AI",
              "Hai strumenti AI ma non li usi bene",
              "Devi convincere soci o manager a investire in AI",
              "Vuoi accedere a bandi o incentivi pubblici",
            ].map((i) => (
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-md bg-accent-500/15 text-accent-300 mt-0.5">
                  <Icon name="check" class="h-3 w-3" />
                </span>
                {i}
              </li>
            ))}
          </ul>
        </div>
      </Reveal>
    </div>
  </Section>

  <!-- CTA -->
  <Section padding="xl" border={false}>
    <Reveal>
      <div class="relative overflow-hidden rounded-3xl border border-brand-500/30 bg-surface-800/40 backdrop-blur-md p-10 md:p-16 text-center">
        <div class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 h-[400px] w-[700px] bg-aurora-gradient opacity-25 blur-4xl rounded-full"></div>
        <div class="relative">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
            Workshop per la tua azienda<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">o per un gruppo locale.</span>
          </h2>
          <p class="text-slate-400 mb-8 max-w-xl mx-auto">Sede a Carmagnola, disponibili su tutto il Piemonte e in modalità video in tutta Italia.</p>
          <Button href="/contatti?interesse=Formazione+AI" variant="primary" size="lg">
            Richiedi informazioni
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
        </div>
      </div>
    </Reveal>
  </Section>

  </main>
  <Footer />
</Layout>
