---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Heading from '../components/ui/Heading.astro';
import Icon from '../components/ui/Icon.astro';
import Reveal from '../components/ui/Reveal.astro';
import Marquee from '../components/ui/Marquee.astro';
import FloatingNodes from '../components/three/FloatingNodes.astro';

const usecases = [
  { icon: "mail", title: "Gestione email e richieste", desc: "L'AI legge le email in arrivo, le classifica, risponde alle FAQ e assegna quelle complesse al referente corretto. Zero email perse." },
  { icon: "file-text", title: "Preventivi automatici", desc: "Il cliente compila un modulo, l'AI genera la bozza del preventivo basandosi su listini e specifiche. Tu la rivedi e la invii in 5 minuti." },
  { icon: "workflow", title: "Follow-up commerciale", desc: "Sequenze automatiche email/WhatsApp per ricontattare i lead in modo personalizzato e al momento giusto, senza dimenticarsi nessuno." },
  { icon: "database", title: "Elaborazione documenti", desc: "Fatture, contratti, bolle: l'AI estrae i dati chiave, li verifica e li inserisce nel gestionale. Niente trascrizione manuale." },
  { icon: "calendar", title: "Appuntamenti e prenotazioni", desc: "Il cliente sceglie orario e servizio autonomamente. Conferme, promemoria e modifiche gestiti senza staff." },
  { icon: "bar", title: "Report e analisi", desc: "KPI, vendite, scadenze: l'AI prepara report periodici e li invia al team o al titolare senza che nessuno estragga dati." },
];

const tools = ["Make · Integromat", "n8n", "Zapier", "OpenAI API", "Anthropic Claude", "Notion", "Google Workspace", "HubSpot CRM", "Fatture in Cloud", "Airtable", "WhatsApp Business", "Twilio", "Slack", "Stripe"];
---

<Layout
  title="Automazioni AI"
  description="Automatizza email, preventivi, documenti, follow-up con l'AI. Risparmia 2-5 ore al giorno. Soluzioni su misura per PMI italiane."
>
  <Header />
  <main id="main">

  <!-- HERO -->
  <section class="relative overflow-hidden pt-12 pb-24 sm:pt-16">
    <div class="pointer-events-none absolute inset-0 bg-grid-pattern bg-grid opacity-[0.15] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000,transparent_70%)]"></div>
    <div class="pointer-events-none absolute inset-0">
      <FloatingNodes class="opacity-50" height="100%" />
    </div>
    <div class="pointer-events-none absolute -top-40 right-1/4 h-[500px] w-[700px] bg-accent-500/15 blur-4xl rounded-full"></div>

    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <Reveal class="inline-flex">
        <Badge variant="brand">
          <Icon name="zap" class="h-3 w-3" />
          Automazioni AI
        </Badge>
      </Reveal>
      <Reveal delay={120}>
        <h1 class="mt-6 font-display text-4xl sm:text-5xl lg:text-[4rem] font-bold text-white leading-[1.05]">
          Smetti di fare<br />
          <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">
            le stesse cose ogni giorno.
          </span>
        </h1>
      </Reveal>
      <Reveal delay={250}>
        <p class="mt-7 text-lg text-slate-400 leading-relaxed max-w-2xl mx-auto">
          Email, preventivi, documenti, follow-up, appuntamenti, report.
          Ogni processo ripetitivo che esegui manualmente è un'ora persa.
          <strong class="text-white">L'AI può gestirlo al posto tuo.</strong>
        </p>
      </Reveal>
      <Reveal delay={400}>
        <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button href="/contatti?interesse=Automazioni+AI" variant="primary" size="lg">
            Diagnosi gratuita
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
          <Button href="#casi-uso" variant="secondary" size="lg">Vedi esempi</Button>
        </div>
      </Reveal>
    </div>

    <!-- Stats inline -->
    <div class="relative mt-20 max-w-5xl mx-auto px-4">
      <div class="rounded-3xl border border-white/10 bg-surface-800/60 backdrop-blur-md overflow-hidden">
        <div class="grid grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-white/5">
          {[
            { v: "2-5h", l: "risparmiate al giorno per collaboratore" },
            { v: "70%", l: "riduzione errori di trascrizione" },
            { v: "2 sett.", l: "per la prima automazione in produzione" },
            { v: "ROI 200%+", l: "stimato in 6-12 mesi" },
          ].map((s, i) => (
            <Reveal delay={i * 100}>
              <div class="p-6 sm:p-7 text-center lg:text-left">
                <div class="font-display text-3xl font-bold bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">{s.v}</div>
                <div class="mt-1.5 text-xs text-slate-400 leading-snug">{s.l}</div>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <Section id="casi-uso" variant="glow" padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Cosa puoi automatizzare" level={2} highlight="ogni giorno">
          I processi che automatizziamo
        </Heading>
      </Reveal>
      <Reveal delay={120}>
        <p class="mt-5 text-slate-400 max-w-xl mx-auto">
          Questi sono i flussi più richiesti, ma ogni azienda ha i propri. Partiamo da quello che ti costa di più.
        </p>
      </Reveal>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {usecases.map((u, i) => (
        <Reveal delay={i * 80}>
          <div class="group relative rounded-2xl border border-white/5 bg-surface-800/80 backdrop-blur-sm p-6 hover:border-brand-500/30 transition-all hover:-translate-y-1 duration-300 h-full">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/10 text-brand-300 mb-5 group-hover:bg-brand-500/20 transition-colors">
              <Icon name={u.icon} class="h-5 w-5" />
            </div>
            <h3 class="text-base font-semibold text-white mb-2 font-display">{u.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{u.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- TOOLS -->
  <Section variant="dark" padding="lg">
    <div class="text-center mb-8">
      <Reveal>
        <Heading eyebrow="Stack" level={3}>Strumenti e piattaforme che integriamo</Heading>
      </Reveal>
    </div>
    <Marquee items={tools} />
    <p class="mt-8 text-center text-xs text-slate-500">E molti altri. Se hai già un sistema in uso, partiamo da quello.</p>
  </Section>

  <!-- HOW WE BUILD -->
  <Section padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Come costruiamo" level={2}>
          Da processo manuale ad automazione
        </Heading>
      </Reveal>
    </div>

    <div class="grid lg:grid-cols-4 gap-5">
      {[
        { num: "01", title: "Mappiamo il processo", desc: "Capiamo input, output, casi limite. Stimiamo ore e costi attuali." },
        { num: "02", title: "Disegniamo il flusso", desc: "Workflow no-code/low-code con step di review umana dove serve." },
        { num: "03", title: "Mettiamo in produzione", desc: "Test su casi reali, monitoring degli errori, alert per anomalie." },
        { num: "04", title: "Misuriamo + scaliamo", desc: "Report KPI, ottimizzazione continua. Aggiungiamo step quando ha senso." },
      ].map((s, i) => (
        <Reveal delay={i * 100}>
          <div class="rounded-2xl border border-white/5 bg-surface-800/80 backdrop-blur-sm p-6 h-full">
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">step</span>
              <span class="font-display text-3xl font-bold bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">{s.num}</span>
            </div>
            <h3 class="text-base font-semibold text-white mb-2 font-display">{s.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{s.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section padding="xl" border={false}>
    <Reveal>
      <div class="relative overflow-hidden rounded-3xl border border-brand-500/30 bg-surface-800/40 backdrop-blur-md p-10 md:p-16 text-center">
        <div class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 h-[400px] w-[700px] bg-aurora-gradient opacity-25 blur-4xl rounded-full"></div>
        <div class="relative">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
            Qual è il processo che ti<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">costa più tempo ogni giorno?</span>
          </h2>
          <p class="text-slate-400 mb-8 max-w-xl mx-auto">Dimmelo nella diagnosi gratuita. In 30 minuti ti mostriamo se e come automatizzarlo.</p>
          <Button href="/contatti?interesse=Automazioni+AI" variant="primary" size="lg">
            Prenota diagnosi gratuita
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
        </div>
      </div>
    </Reveal>
  </Section>

  </main>
  <Footer />
</Layout>
