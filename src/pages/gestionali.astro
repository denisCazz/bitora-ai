---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Heading from '../components/ui/Heading.astro';
import Icon from '../components/ui/Icon.astro';
import Reveal from '../components/ui/Reveal.astro';

const modules = [
  { icon: "search", title: "Ricerca intelligente", desc: "Cerca in testo libero tra clienti, prodotti, interventi, documenti. L'AI capisce la domanda e restituisce esattamente quello che cerchi." },
  { icon: "file-text", title: "Riepiloghi automatici", desc: "Riepilogo cliente, trattativa o intervento generato in un click. Meno tempo sulle note, più tempo sul lavoro." },
  { icon: "database", title: "Estrazione dati documenti", desc: "Fatture, contratti, bolle in PDF: l'AI estrae i campi, verifica e inserisce nei campi giusti del gestionale." },
  { icon: "sparkles", title: "Suggerimenti commerciali", desc: "L'AI analizza lo storico cliente e suggerisce upsell, cross-sell o rinnovo al momento giusto." },
  { icon: "bar", title: "Report predittivi", desc: "Pipeline commerciale, scadenze, anomalie evidenziate proattivamente. Report settimanali generati in automatico." },
  { icon: "bot", title: "Assistente AI interno", desc: "Il team interroga il gestionale in linguaggio naturale. Niente filtri complessi: chiede e l'AI risponde." },
];
---

<Layout
  title="CRM e Gestionali con AI"
  description="Aggiungi AI al tuo CRM e gestionale Bitora: ricerca intelligente, riepiloghi automatici, estrazione dati da documenti e report predittivi."
>
  <Header />
  <main id="main">

  <!-- HERO -->
  <section class="relative overflow-hidden pt-12 pb-24 sm:pt-16">
    <div class="pointer-events-none absolute inset-0 bg-grid-pattern bg-grid opacity-[0.15] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000,transparent_70%)]"></div>
    <div class="pointer-events-none absolute -top-40 right-1/4 h-[500px] w-[700px] bg-brand-500/15 blur-4xl rounded-full"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-5 gap-12 items-center">
      <div class="lg:col-span-3">
        <Reveal class="inline-flex">
          <Badge variant="brand">
            <Icon name="database" class="h-3 w-3" />
            CRM e Gestionali con AI
          </Badge>
        </Reveal>
        <Reveal delay={120}>
          <h1 class="mt-6 font-display text-4xl sm:text-5xl lg:text-[3.5rem] font-bold text-white leading-[1.05]">
            Il tuo gestionale,<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">finalmente intelligente.</span>
          </h1>
        </Reveal>
        <Reveal delay={250}>
          <p class="mt-6 text-lg text-slate-400 leading-relaxed">
            CRM, CMMS e gestionali Bitora potenziati con moduli AI: ricerca in linguaggio naturale,
            riepiloghi automatici, estrazione dati da documenti, report predittivi.
            <strong class="text-white">Senza cambiare i tuoi flussi di lavoro.</strong>
          </p>
        </Reveal>
        <Reveal delay={400}>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="/contatti?interesse=Gestionale+con+AI" variant="primary" size="lg">
              Parla con noi
              <Icon name="arrow" class="h-4 w-4" />
            </Button>
            <Button href="https://bitora.it/sistemi-aziendali" variant="secondary" size="lg" external>
              Gestionali Bitora
              <Icon name="arrow" class="h-4 w-4" />
            </Button>
          </div>
        </Reveal>
      </div>

      <!-- Visual: query bar mockup -->
      <Reveal delay={200} class="lg:col-span-2">
        <div class="relative">
          <div class="absolute -inset-6 bg-aurora-gradient opacity-20 blur-4xl rounded-[2rem]"></div>
          <div class="relative rounded-2xl border border-white/10 bg-surface-800/90 backdrop-blur-xl shadow-2xl shadow-brand-600/20 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-surface-700/40">
              <span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">CRM · query AI</span>
              <span class="ml-auto h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span>
            </div>
            <div class="p-5 space-y-3">
              <div class="rounded-xl bg-surface-900/60 border border-white/5 p-3">
                <div class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">domanda</div>
                <div class="text-sm text-slate-200 font-mono">› clienti che non comprano da 6 mesi e hanno speso più di 5k</div>
              </div>
              <div class="flex items-center gap-2 text-[11px] text-brand-300 font-mono">
                <Icon name="sparkles" class="h-3 w-3" />
                AI ha trovato 23 clienti
              </div>
              <div class="space-y-2">
                {[
                  { name: "Edilizia Rossi srl", spent: "€18.4k", days: "212g" },
                  { name: "Studio Bianchi", spent: "€7.2k", days: "189g" },
                  { name: "AgriPiemonte", spent: "€11.8k", days: "204g" },
                ].map((c) => (
                  <div class="flex items-center justify-between rounded-lg border border-white/5 bg-white/[0.03] px-3 py-2 text-xs">
                    <span class="text-white">{c.name}</span>
                    <span class="font-mono text-[10px] text-slate-400">{c.spent} · {c.days}</span>
                  </div>
                ))}
              </div>
              <div class="flex items-center gap-2 mt-4 pt-3 border-t border-white/5">
                <div class="flex-1 rounded-lg bg-white/5 px-3 py-2 text-[11px] text-slate-500 font-mono">chiedi qualcos'altro...</div>
                <div class="h-7 w-7 rounded-lg bg-brand-gradient flex items-center justify-center text-white">
                  <Icon name="arrow" class="h-3.5 w-3.5" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- MODULES -->
  <Section variant="glow" padding="xl">
    <div class="text-center mb-14">
      <Reveal>
        <Heading eyebrow="Moduli disponibili" level={2} highlight="dei sistemi Bitora">
          AI integrata dentro
        </Heading>
      </Reveal>
      <Reveal delay={120}>
        <p class="mt-5 text-slate-400 max-w-xl mx-auto">
          I moduli si integrano nei gestionali Bitora esistenti. Se hai un sistema di terze parti, valutiamo l'integrazione in fase di diagnosi.
        </p>
      </Reveal>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {modules.map((m, i) => (
        <Reveal delay={i * 80}>
          <div class="group relative rounded-2xl border border-white/5 bg-surface-800/80 backdrop-blur-sm p-6 hover:border-brand-500/30 transition-all hover:-translate-y-1 duration-300 h-full">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/10 text-brand-300 mb-5 group-hover:bg-brand-500/20 transition-colors">
              <Icon name={m.icon} class="h-5 w-5" />
            </div>
            <h3 class="text-base font-semibold text-white mb-2 font-display">{m.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{m.desc}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </Section>

  <!-- BITORA CLIENT -->
  <Section variant="dark" padding="lg">
    <Reveal>
      <div class="relative overflow-hidden rounded-3xl border border-brand-500/30 bg-surface-800/60 backdrop-blur-md p-8 md:p-14 text-center">
        <div class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 h-[300px] w-[600px] bg-aurora-gradient opacity-20 blur-4xl rounded-full"></div>
        <div class="relative">
          <Badge variant="electric">Già cliente Bitora?</Badge>
          <h2 class="mt-5 font-display text-2xl sm:text-3xl font-bold text-white max-w-2xl mx-auto">
            Se hai già un gestionale Bitora,<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">l'integrazione AI è naturale.</span>
          </h2>
          <p class="text-slate-400 max-w-xl mx-auto mt-5 text-sm leading-relaxed">
            Conosciamo già la tua architettura e possiamo aggiungere AI senza stravolgere nulla.
            Compatibile bandi Transizione 5.0.
          </p>
          <div class="mt-8">
            <Button href="/contatti?interesse=Gestionale+con+AI&pack=custom" variant="primary" size="lg">
              Aggiorna il mio gestionale
              <Icon name="arrow" class="h-4 w-4" />
            </Button>
          </div>
        </div>
      </div>
    </Reveal>
  </Section>

  <!-- CTA -->
  <Section padding="xl" border={false}>
    <Reveal>
      <div class="relative overflow-hidden rounded-3xl border border-brand-500/30 bg-surface-800/40 backdrop-blur-md p-10 md:p-16 text-center">
        <div class="pointer-events-none absolute -top-20 left-1/2 -translate-x-1/2 h-[400px] w-[700px] bg-aurora-gradient opacity-25 blur-4xl rounded-full"></div>
        <div class="relative">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">Pronto a rendere<br />
            <span class="bg-aurora-gradient bg-clip-text text-transparent bg-[length:200%_200%] animate-aurora">intelligente il tuo sistema?</span>
          </h2>
          <p class="text-slate-400 mb-8 max-w-xl mx-auto">In 30 minuti capiamo dove l'AI porta più valore nella tua operatività.</p>
          <Button href="/contatti?interesse=Gestionale+con+AI" variant="primary" size="lg">
            Prenota diagnosi gratuita
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
        </div>
      </div>
    </Reveal>
  </Section>

  </main>
  <Footer />
</Layout>
