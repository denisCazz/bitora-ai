---
interface Props {
  class?: string;
  height?: string;
  variant?: 'network' | 'flow';
}
const { class: className = '', height = '380px', variant = 'network' } = Astro.props;
---

<div
  class={`floating-nodes relative w-full ${className}`}
  style={`height:${height}`}
  data-nodes-variant={variant}
>
  <div class="nodes-fallback absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="h-48 w-48 rounded-full bg-brand-gradient opacity-40 blur-3xl"></div>
  </div>
  <canvas class="nodes-canvas absolute inset-0 h-full w-full hidden"></canvas>
</div>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    document.querySelectorAll<HTMLElement>('.floating-nodes').forEach(initNodes);
  }

  function initNodes(host: HTMLElement) {
    const canvas = host.querySelector<HTMLCanvasElement>('.nodes-canvas');
    const fallback = host.querySelector<HTMLElement>('.nodes-fallback');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    canvas.classList.remove('hidden');
    fallback?.classList.add('hidden');

    const variant = host.dataset.nodesVariant ?? 'network';
    const NUM = variant === 'flow' ? 14 : 22;
    const nodes: { x: number; y: number; z: number; r: number; pulse: number }[] = [];
    let w = 0, h = 0;

    function resize() {
      const rect = host.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio, 2);
      w = rect.width;
      h = rect.height;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      canvas!.style.width = `${w}px`;
      canvas!.style.height = `${h}px`;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    for (let i = 0; i < NUM; i++) {
      nodes.push({
        x: Math.random(),
        y: Math.random(),
        z: Math.random(),
        r: 2 + Math.random() * 3,
        pulse: Math.random() * Math.PI * 2,
      });
    }

    let mx = 0.5, my = 0.5;
    host.addEventListener('pointermove', (e) => {
      const rect = host.getBoundingClientRect();
      mx = (e.clientX - rect.left) / rect.width;
      my = (e.clientY - rect.top) / rect.height;
    });

    let running = true;
    const observer = new IntersectionObserver(([entry]) => {
      running = entry.isIntersecting;
    }, { threshold: 0 });
    observer.observe(host);

    function draw(time: number) {
      if (running && ctx) {
        ctx.clearRect(0, 0, w, h);
        // edges
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i];
            const b = nodes[j];
            const dx = (a.x - b.x) * w;
            const dy = (a.y - b.y) * h;
            const d = Math.hypot(dx, dy);
            const max = variant === 'flow' ? 220 : 160;
            if (d < max) {
              const alpha = (1 - d / max) * 0.35;
              const grad = ctx.createLinearGradient(a.x * w, a.y * h, b.x * w, b.y * h);
              grad.addColorStop(0, `rgba(99,102,241,${alpha})`);
              grad.addColorStop(1, `rgba(34,211,238,${alpha})`);
              ctx.strokeStyle = grad;
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(a.x * w, a.y * h);
              ctx.lineTo(b.x * w, b.y * h);
              ctx.stroke();
            }
          }
        }
        // nodes
        for (const n of nodes) {
          const drift = Math.sin(time * 0.0004 + n.pulse) * 0.012;
          n.x += drift * (0.5 - n.x) * 0.05 + (mx - 0.5) * 0.0003;
          n.y += Math.cos(time * 0.0004 + n.pulse) * 0.008 * 0.5 + (my - 0.5) * 0.0003;
          // mantieni dentro
          n.x = Math.max(0.02, Math.min(0.98, n.x));
          n.y = Math.max(0.02, Math.min(0.98, n.y));

          const px = n.x * w;
          const py = n.y * h;
          const radius = n.r + Math.sin(time * 0.002 + n.pulse) * 1.2;
          const grd = ctx.createRadialGradient(px, py, 0, px, py, radius * 4);
          grd.addColorStop(0, 'rgba(165,180,252,0.95)');
          grd.addColorStop(0.4, 'rgba(99,102,241,0.5)');
          grd.addColorStop(1, 'rgba(99,102,241,0)');
          ctx.fillStyle = grd;
          ctx.beginPath();
          ctx.arc(px, py, radius * 4, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = '#a5b4fc';
          ctx.beginPath();
          ctx.arc(px, py, radius, 0, Math.PI * 2);
          ctx.fill();
        }
      }
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  }
</script>
