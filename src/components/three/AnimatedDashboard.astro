---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`relative ${className}`}>
  <!-- Glow halo -->
  <div class="absolute -inset-8 bg-aurora-gradient opacity-20 blur-4xl rounded-full"></div>

  <div
    class="dashboard-3d relative rounded-2xl border border-white/10 bg-surface-800/90 backdrop-blur-xl shadow-2xl shadow-brand-600/30 overflow-hidden"
    style="transform: perspective(1400px) rotateY(-12deg) rotateX(8deg) translateZ(0);"
  >
    <!-- Top bar -->
    <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-surface-700/60">
      <div class="flex gap-1.5">
        <span class="h-2.5 w-2.5 rounded-full bg-red-500/60"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/60"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-green-500/60"></span>
      </div>
      <div class="ml-3 flex items-center gap-2 text-[10px] text-slate-500 font-mono">
        <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span>
        ai.bitora.it / dashboard
      </div>
    </div>

    <!-- Body grid -->
    <div class="grid grid-cols-3 gap-3 p-4">
      <!-- KPI tile 1 -->
      <div class="rounded-xl border border-white/5 bg-surface-900/60 p-3">
        <div class="text-[9px] uppercase tracking-wider text-slate-500">Ore risparmiate</div>
        <div class="mt-1 text-xl font-bold text-white font-display" data-counter="42">0</div>
        <div class="mt-2 flex items-end gap-0.5 h-6">
          {[40, 55, 35, 70, 45, 80, 65, 90].map((v) => (
            <div class="flex-1 rounded-sm bg-brand-gradient" style={`height:${v}%;opacity:${0.35 + v / 200}`}></div>
          ))}
        </div>
      </div>
      <!-- KPI tile 2 -->
      <div class="rounded-xl border border-white/5 bg-surface-900/60 p-3">
        <div class="text-[9px] uppercase tracking-wider text-slate-500">Lead gestiti</div>
        <div class="mt-1 text-xl font-bold text-white font-display" data-counter="184">0</div>
        <div class="mt-2 flex items-center gap-1 text-[9px] font-mono">
          <span class="text-green-400">▲ 23%</span>
          <span class="text-slate-500">vs. mese scorso</span>
        </div>
      </div>
      <!-- KPI tile 3 -->
      <div class="rounded-xl border border-white/5 bg-surface-900/60 p-3">
        <div class="text-[9px] uppercase tracking-wider text-slate-500">Risposta media</div>
        <div class="mt-1 text-xl font-bold text-white font-display"><span data-counter="2.4">0</span>s</div>
        <div class="mt-2 flex items-center gap-1 text-[9px] font-mono">
          <span class="text-accent-400">●</span>
          <span class="text-slate-500">H24 attivo</span>
        </div>
      </div>

      <!-- Main chart -->
      <div class="col-span-2 rounded-xl border border-white/5 bg-surface-900/60 p-3 row-span-2">
        <div class="flex items-center justify-between mb-2">
          <div class="text-[10px] uppercase tracking-wider text-slate-500">Richieste automatizzate · settimana</div>
          <div class="flex gap-1">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-400"></span>
            <span class="text-[9px] text-slate-400">AI</span>
            <span class="h-1.5 w-1.5 rounded-full bg-accent-400 ml-1"></span>
            <span class="text-[9px] text-slate-400">Umano</span>
          </div>
        </div>
        <svg viewBox="0 0 200 90" class="w-full h-32" preserveAspectRatio="none">
          <defs>
            <linearGradient id="g1" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#6366f1" stop-opacity="0.45"/>
              <stop offset="100%" stop-color="#6366f1" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <path d="M0 70 L25 55 L50 60 L75 35 L100 45 L125 25 L150 30 L175 18 L200 22 L200 90 L0 90 Z" fill="url(#g1)"/>
          <path d="M0 70 L25 55 L50 60 L75 35 L100 45 L125 25 L150 30 L175 18 L200 22" stroke="#a5b4fc" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round" pathLength="100" class="dash-anim"/>
          <path d="M0 80 L25 75 L50 78 L75 65 L100 70 L125 60 L150 65 L175 55 L200 60" stroke="#22d3ee" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="3 3" pathLength="100"/>
        </svg>
      </div>

      <!-- Activity feed -->
      <div class="rounded-xl border border-white/5 bg-surface-900/60 p-3 row-span-2">
        <div class="text-[10px] uppercase tracking-wider text-slate-500 mb-2">Live activity</div>
        <ul class="space-y-2 text-[10px]">
          {[
            { dot: 'bg-green-400', label: 'Chatbot ha risposto a 12 richieste' },
            { dot: 'bg-brand-400', label: 'Preventivo auto-generato' },
            { dot: 'bg-accent-400', label: 'Email lead qualificato' },
            { dot: 'bg-electric-400', label: 'Documento PDF estratto' },
          ].map((i, idx) => (
            <li class="flex items-start gap-2 activity-item" style={`animation-delay:${idx * 0.4}s`}>
              <span class={`h-1.5 w-1.5 rounded-full ${i.dot} mt-1 shrink-0 animate-pulse`}></span>
              <span class="text-slate-300 leading-snug">{i.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
  // counter animation when in viewport
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const target = parseFloat(el.dataset.counter ?? '0');
      const decimals = (el.dataset.counter ?? '').includes('.') ? 1 : 0;
      const start = performance.now();
      const dur = 1400;
      function step(t: number) {
        const p = Math.min(1, (t - start) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        const v = (target * eased).toFixed(decimals);
        el.textContent = v;
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      obs.unobserve(el);
    });
  }, { threshold: 0.4 });
  counters.forEach((c) => obs.observe(c));
</script>

<style>
  .dash-anim {
    stroke-dasharray: 100 100;
    stroke-dashoffset: 100;
    animation: drawLine 2.4s ease-out forwards;
  }
  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }
  .activity-item {
    opacity: 0;
    transform: translateX(-8px);
    animation: slideIn 0.6s ease-out forwards;
  }
  @keyframes slideIn {
    to { opacity: 1; transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dashboard-3d {
      transform: none !important;
    }
  }
</style>
