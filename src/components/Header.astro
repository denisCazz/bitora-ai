---
import Icon from './ui/Icon.astro';

const navLinks = [
  { label: "Automazioni", href: "/automazioni" },
  { label: "Chatbot AI",  href: "/chatbot"     },
  { label: "Siti Web",    href: "/siti-web"    },
  { label: "Gestionali",  href: "/gestionali"  },
  { label: "Formazione",  href: "/formazione"  },
  { label: "Casi Studio", href: "/casi-studio" },
];

const currentPath = Astro.url.pathname;
const PHONE = "3514979670";
const WA_URL = `https://wa.me/39${PHONE}`;
---

<!-- Gradient top bar -->
<div class="fixed top-0 left-0 right-0 z-50 h-px bg-gradient-to-r from-transparent via-brand-500/60 to-transparent pointer-events-none"></div>

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-500"
>
  <!-- Background layer (scroll-aware) -->
  <div
    class="header-bg absolute inset-0 border-b border-transparent transition-all duration-500"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-[68px] items-center gap-6">

      <!-- ── Logo ─────────────────────────────────────────────── -->
      <a href="/" class="flex shrink-0 items-center gap-3 group" aria-label="Bitora AI homepage">
        <!-- Icon container -->
        <div class="relative flex h-9 w-9 items-center justify-center rounded-xl bg-brand-gradient shadow-glow-soft">
          <span class="absolute -inset-px rounded-xl bg-brand-gradient opacity-0 blur-md group-hover:opacity-80 transition-opacity duration-300"></span>
          <svg class="relative h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l7 4v8l-7 4-7-4V6z"/>
            <path d="M12 2v16M5 6l7 4 7-4"/>
          </svg>
          <!-- Pulsing dot -->
          <span class="absolute -right-0.5 -top-0.5 flex h-2 w-2" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full bg-accent-400 opacity-75 animate-ping"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-400"></span>
          </span>
        </div>
        <!-- Wordmark -->
        <div class="flex flex-col leading-none">
          <span class="text-[15px] font-bold text-white tracking-tight font-display">
            Bitora <span class="bg-brand-gradient bg-clip-text text-transparent">AI</span>
          </span>
          <span class="text-[10px] text-slate-500 leading-none tracking-wide">by bitora.it</span>
        </div>
      </a>

      <!-- ── Desktop nav (pill glass) ─────────────────────────── -->
      <nav
        class="hidden lg:flex flex-1 items-center justify-center"
        aria-label="Navigazione principale"
      >
        <div class="flex items-center gap-0.5 rounded-full border border-white/[0.08] bg-white/[0.04] px-1.5 py-1.5 backdrop-blur-md">
          {navLinks.map((link) => {
            const isActive =
              link.href === '/'
                ? currentPath === '/'
                : currentPath === link.href || currentPath.startsWith(link.href + '/');
            return (
              <a
                href={link.href}
                class={`relative px-3.5 py-1.5 rounded-full text-[13px] font-medium transition-all duration-200 whitespace-nowrap ${
                  isActive
                    ? 'bg-brand-gradient text-white shadow-glow-soft'
                    : 'text-slate-400 hover:text-white hover:bg-white/[0.06]'
                }`}
              >
                {link.label}
              </a>
            );
          })}
        </div>
      </nav>

      <!-- ── Right actions ─────────────────────────────────────── -->
      <div class="ml-auto flex shrink-0 items-center gap-2">
        <!-- WhatsApp link (desktop) -->
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Scrivici su WhatsApp"
          class="hidden md:inline-flex items-center gap-1.5 text-[13px] text-slate-400 hover:text-white transition-colors duration-200 px-2 py-1.5 rounded-lg hover:bg-white/[0.06]"
        >
          <svg class="h-3.5 w-3.5 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.553 4.116 1.522 5.847L.057 23.882a.5.5 0 00.614.612l6.194-1.623A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.884 9.884 0 01-5.031-1.375l-.362-.213-3.732.979 1.001-3.637-.234-.374A9.857 9.857 0 012.1 12C2.1 6.529 6.529 2.1 12 2.1S21.9 6.529 21.9 12 17.471 21.9 12 21.9z"/>
          </svg>
          <span class="hidden xl:inline">{PHONE}</span>
        </a>

        <!-- CTA button -->
        <a
          href="/contatti"
          class="inline-flex relative items-center gap-1.5 rounded-full bg-brand-gradient px-4 py-2 text-[13px] font-semibold text-white shadow-glow-soft hover:shadow-glow-brand hover:-translate-y-0.5 transition-all duration-200 ease-spring overflow-hidden group/cta"
        >
          <span class="absolute inset-0 bg-gradient-to-r from-brand-400 to-accent-400 opacity-0 group-hover/cta:opacity-100 transition-opacity duration-300"></span>
          <span class="relative">Diagnosi gratuita</span>
          <Icon name="arrow" class="relative h-3.5 w-3.5 group-hover/cta:translate-x-0.5 transition-transform" />
        </a>

        <!-- Mobile toggle -->
        <button
          id="mobile-toggle"
          aria-label="Apri menu"
          aria-expanded="false"
          aria-controls="mobile-drawer"
          class="lg:hidden flex h-10 w-10 items-center justify-center rounded-full border border-white/[0.08] bg-white/[0.04] text-slate-300 hover:text-white hover:bg-white/[0.08] transition-all duration-200"
        >
          <Icon name="menu" class="h-5 w-5 menu-open" />
          <Icon name="x" class="h-5 w-5 menu-close hidden" />
        </button>
      </div>

    </div>
  </div>
</header>

<!-- ── Mobile drawer ──────────────────────────────────────────────── -->
<div id="mobile-drawer" class="lg:hidden fixed inset-0 z-40 pointer-events-none" aria-hidden="true">
  <!-- Backdrop -->
  <div class="drawer-backdrop absolute inset-0 bg-surface-950/80 backdrop-blur-xl opacity-0 transition-opacity duration-300"></div>

  <!-- Panel -->
  <aside class="drawer-panel absolute right-0 top-0 h-full w-[85%] max-w-sm translate-x-full bg-surface-900/95 backdrop-blur-xl border-l border-white/[0.08] transition-transform duration-300 ease-spring overflow-y-auto flex flex-col">

    <!-- Panel header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-white/[0.06]">
      <div class="flex items-center gap-2.5">
        <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand-gradient">
          <svg class="h-3.5 w-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l7 4v8l-7 4-7-4V6z"/>
            <path d="M12 2v16M5 6l7 4 7-4"/>
          </svg>
        </div>
        <span class="text-[14px] font-bold text-white font-display">Bitora <span class="text-accent-400">AI</span></span>
      </div>
      <button
        class="drawer-close flex h-9 w-9 items-center justify-center rounded-full border border-white/[0.08] text-slate-400 hover:text-white hover:bg-white/[0.06] transition-all"
        aria-label="Chiudi menu"
      >
        <Icon name="x" class="h-4.5 w-4.5" />
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 p-4 flex flex-col gap-1" aria-label="Navigazione mobile">
      {navLinks.map((link) => {
        const isActive =
          link.href === '/'
            ? currentPath === '/'
            : currentPath === link.href || currentPath.startsWith(link.href + '/');
        return (
          <a
            href={link.href}
            class={`flex items-center justify-between rounded-xl px-4 py-3.5 text-[15px] font-medium transition-all duration-200 ${
              isActive
                ? 'bg-brand-500/15 text-white border border-brand-500/25'
                : 'text-slate-300 hover:bg-white/[0.05] hover:text-white border border-transparent'
            }`}
          >
            <span>{link.label}</span>
            <Icon name="arrow" class="h-4 w-4 text-slate-500" />
          </a>
        );
      })}
    </nav>

    <!-- Panel footer CTAs -->
    <div class="p-4 border-t border-white/[0.06] space-y-2.5">
      <a
        href="/contatti"
        class="flex items-center justify-center gap-2 w-full rounded-xl bg-brand-gradient px-5 py-3.5 text-[14px] font-semibold text-white shadow-glow-soft"
      >
        Diagnosi AI gratuita
        <Icon name="arrow" class="h-4 w-4" />
      </a>
      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full rounded-xl border border-white/[0.08] bg-white/[0.04] px-5 py-3.5 text-[14px] font-medium text-slate-200 hover:bg-white/[0.07] transition-colors"
      >
        <svg class="h-4 w-4 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.553 4.116 1.522 5.847L.057 23.882a.5.5 0 00.614.612l6.194-1.623A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9a9.884 9.884 0 01-5.031-1.375l-.362-.213-3.732.979 1.001-3.637-.234-.374A9.857 9.857 0 012.1 12C2.1 6.529 6.529 2.1 12 2.1S21.9 6.529 21.9 12 17.471 21.9 12 21.9z"/>
        </svg>
        WhatsApp {PHONE}
      </a>
    </div>

  </aside>
</div>

<!-- Spacer -->
<div class="h-[68px]"></div>

<script>
  // ── Scroll-aware header ────────────────────────────────────────────
  const header = document.getElementById('site-header');
  const bg = header?.querySelector<HTMLElement>('.header-bg');
  function updateHeaderBg() {
    if (!bg) return;
    if (window.scrollY > 12) {
      bg.classList.add('bg-surface-900/75', 'backdrop-blur-xl', 'border-white/[0.06]');
      bg.classList.remove('border-transparent');
    } else {
      bg.classList.remove('bg-surface-900/75', 'backdrop-blur-xl', 'border-white/[0.06]');
      bg.classList.add('border-transparent');
    }
  }
  window.addEventListener('scroll', updateHeaderBg, { passive: true });
  updateHeaderBg();

  // ── Mobile drawer ─────────────────────────────────────────────────
  const toggle  = document.getElementById('mobile-toggle');
  const drawer  = document.getElementById('mobile-drawer');
  const backdrop = drawer?.querySelector<HTMLElement>('.drawer-backdrop');
  const panel   = drawer?.querySelector<HTMLElement>('.drawer-panel');
  const iconOpen  = toggle?.querySelector<HTMLElement>('.menu-open');
  const iconClose = toggle?.querySelector<HTMLElement>('.menu-close');

  function openDrawer() {
    if (!drawer || !panel || !backdrop) return;
    drawer.removeAttribute('aria-hidden');
    drawer.setAttribute('aria-hidden', 'false');
    drawer.classList.remove('pointer-events-none');
    backdrop.classList.add('opacity-100');
    panel.classList.remove('translate-x-full');
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    if (!drawer || !panel || !backdrop) return;
    drawer.setAttribute('aria-hidden', 'true');
    drawer.classList.add('pointer-events-none');
    backdrop.classList.remove('opacity-100');
    panel.classList.add('translate-x-full');
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () =>
    drawer?.getAttribute('aria-hidden') === 'true' ? openDrawer() : closeDrawer()
  );

  // Close on backdrop click
  backdrop?.addEventListener('click', closeDrawer);

  // Close on link click inside drawer
  panel?.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) =>
    a.addEventListener('click', closeDrawer)
  );

  // Close on X button
  panel?.querySelectorAll<HTMLElement>('.drawer-close').forEach((b) =>
    b.addEventListener('click', closeDrawer)
  );

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });
</script>
