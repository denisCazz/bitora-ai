---
import Icon from './ui/Icon.astro';

const navLinks = [
  { label: "Automazioni", href: "/automazioni" },
  { label: "Chatbot AI",  href: "/chatbot"     },
  { label: "Siti Web",    href: "/siti-web"    },
  { label: "Gestionali",  href: "/gestionali"  },
  { label: "Formazione",  href: "/formazione"  },
  { label: "Casi Studio", href: "/casi-studio" },
  { label: "Contatti",    href: "/contatti"    },
];

const currentPath = Astro.url.pathname;
const PHONE = "3514979670";
const WA_URL = `https://wa.me/39${PHONE}`;
const desktopNavLinks = navLinks.filter((link) => link.href !== '/contatti');
---

<!-- Gradient top line -->
<div class="fixed top-0 left-0 right-0 z-50 h-px bg-gradient-to-r from-transparent via-brand-500/60 to-transparent pointer-events-none"></div>

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-500">
  <!-- Scroll-aware bg -->
  <div class="header-bg absolute inset-0 border-b border-transparent transition-all duration-500" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Mobile/tablet header (< xl): stable 3-column layout -->
    <div class="grid h-16 grid-cols-[40px_minmax(0,1fr)_40px] items-center xl:hidden">
      <button
        id="mobile-toggle"
        aria-label="Apri menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-300 hover:text-white hover:bg-white/10 transition-all duration-200"
      >
        <Icon name="menu" class="h-5 w-5 menu-open" />
        <Icon name="x"    class="h-5 w-5 menu-close hidden" />
      </button>

      <a href="/" class="mx-auto flex min-w-0 items-center gap-2 sm:gap-2.5 group" aria-label="Bitora AI homepage">
        <div class="relative">
          <img
            src="/icona.png"
            alt="Bitora AI"
            width="36"
            height="36"
            class="h-9 w-9 rounded-xl shadow-glow-soft group-hover:shadow-glow-brand transition-shadow duration-300"
          />
          <span class="absolute -right-0.5 -top-0.5 flex h-2 w-2" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full bg-accent-400 opacity-75 animate-ping"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-400"></span>
          </span>
        </div>
        <div class="hidden min-[390px]:flex flex-col leading-none">
          <span class="text-[14px] font-bold text-white tracking-tight font-display">
            Bitora <span class="bg-brand-gradient bg-clip-text text-transparent">AI</span>
          </span>
          <span class="text-[10px] text-slate-500 leading-none">by bitora.it</span>
        </div>
      </a>

      <div aria-hidden="true"></div>
    </div>

    <!-- Desktop header (xl+): no absolute positioning -->
    <div class="hidden h-16 items-center justify-between gap-6 xl:flex">

      <!-- ── Logo ────────────────────────────────────────── -->
      <a href="/" class="flex shrink-0 items-center gap-2.5 group" aria-label="Bitora AI homepage">
        <div class="relative">
          <img
            src="/icona.png"
            alt="Bitora AI"
            width="36"
            height="36"
            class="h-9 w-9 rounded-xl shadow-glow-soft group-hover:shadow-glow-brand transition-shadow duration-300"
          />
          <span class="absolute -right-0.5 -top-0.5 flex h-2 w-2" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full bg-accent-400 opacity-75 animate-ping"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-400"></span>
          </span>
        </div>
        <div class="flex flex-col leading-none">
          <span class="text-[14px] font-bold text-white tracking-tight font-display">
            Bitora <span class="bg-brand-gradient bg-clip-text text-transparent">AI</span>
          </span>
          <span class="text-[10px] text-slate-500 leading-none">by bitora.it</span>
        </div>
      </a>

      <!-- ── Desktop pill nav ────────────────────────────── -->
      <nav class="flex min-w-0 flex-1 items-center justify-center" aria-label="Navigazione principale">
        <div class="flex items-center gap-0.5 rounded-full border border-white/10 bg-white/5 px-1.5 py-1.5 backdrop-blur-md">
          {desktopNavLinks.map((link) => {
            const isActive = link.href === '/'
              ? currentPath === '/'
              : currentPath === link.href || currentPath.startsWith(link.href + '/');
            return (
              <a
                href={link.href}
                class={`px-3.5 py-1.5 rounded-full text-[13px] font-medium transition-all duration-200 whitespace-nowrap ${
                  isActive
                    ? 'bg-brand-gradient text-white shadow-glow-soft'
                    : 'text-slate-400 hover:text-white hover:bg-white/10'
                }`}
              >
                {link.label}
              </a>
            );
          })}
        </div>
      </nav>

      <!-- ── Right actions ────────────────────────────────── -->
      <div class="flex shrink-0 items-center gap-2">

        <!-- WhatsApp -->
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Scrivici su WhatsApp"
          class="inline-flex items-center gap-1.5 text-[13px] text-slate-400 hover:text-white transition-colors duration-200 px-2 py-1.5 rounded-lg hover:bg-white/10"
        >
          <Icon name="whatsapp" class="h-3.5 w-3.5 shrink-0 text-[#25D366]" />
          <span class="hidden xl:inline">{PHONE}</span>
        </a>

        <!-- CTA (lg+ only — mobile gets it inside drawer) -->
        <a
          href="/contatti"
          class="hidden lg:inline-flex relative items-center gap-1.5 rounded-full bg-brand-gradient px-4 py-2 text-[13px] font-semibold text-white shadow-glow-soft hover:shadow-glow-brand hover:-translate-y-0.5 transition-all duration-200 ease-spring overflow-hidden group/cta"
        >
          <span class="absolute inset-0 bg-gradient-to-r from-brand-400 to-accent-400 opacity-0 group-hover/cta:opacity-100 transition-opacity duration-300" aria-hidden="true"></span>
          <span class="relative">Diagnosi gratuita</span>
          <Icon name="arrow" class="relative h-3.5 w-3.5 group-hover/cta:translate-x-0.5 transition-transform" />
        </a>

      </div>

    </div>
  </div>
</header>

<!-- ── Mobile drawer ─────────────────────────────────────────── -->
<div id="mobile-drawer" class="xl:hidden fixed inset-0 z-40 pointer-events-none" aria-hidden="true">
  <div class="drawer-backdrop absolute inset-0 bg-surface-950/80 backdrop-blur-xl opacity-0 transition-opacity duration-300"></div>

  <aside class="drawer-panel absolute right-0 top-0 h-full w-[calc(100vw-3.5rem)] max-w-sm translate-x-full bg-surface-900/95 backdrop-blur-xl border-l border-white/10 transition-transform duration-300 ease-spring overflow-y-auto overflow-x-hidden flex flex-col">

    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
      <div class="flex items-center gap-2.5">
        <img src="/icona.png" alt="Bitora AI" width="28" height="28" class="h-7 w-7 rounded-lg" />
        <span class="text-[14px] font-bold text-white font-display">
          Bitora <span class="text-accent-400">AI</span>
        </span>
      </div>
      <button
        class="drawer-close flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-slate-400 hover:text-white hover:bg-white/5 transition-all"
        aria-label="Chiudi menu"
      >
        <Icon name="x" class="h-5 w-5" />
      </button>
    </div>

    <!-- Links -->
    <nav class="flex-1 p-4 flex flex-col gap-1" aria-label="Navigazione mobile">
      {navLinks.map((link) => {
        const isActive = link.href === '/'
          ? currentPath === '/'
          : currentPath === link.href || currentPath.startsWith(link.href + '/');
        return (
          <a
            href={link.href}
            class={`flex items-center justify-between rounded-xl px-4 py-3.5 text-[15px] font-medium transition-all duration-200 border ${
              isActive
                ? 'bg-brand-500/10 text-white border-brand-500/20'
                : 'text-slate-300 hover:bg-white/5 hover:text-white border-transparent'
            }`}
          >
            <span>{link.label}</span>
            <Icon name="arrow" class="h-4 w-4 text-slate-500 shrink-0" />
          </a>
        );
      })}
    </nav>

    <!-- Footer CTAs -->
    <div class="p-4 border-t border-white/5 space-y-2.5">
      <a
        href="/contatti"
        class="flex items-center justify-center gap-2 w-full rounded-xl bg-brand-gradient px-5 py-3.5 text-[14px] font-semibold text-white shadow-glow-soft"
      >
        Diagnosi AI gratuita
        <Icon name="arrow" class="h-4 w-4" />
      </a>
      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full rounded-xl border border-white/10 bg-white/5 px-5 py-3.5 text-[14px] font-medium text-slate-200 hover:bg-white/10 transition-colors"
      >
        <Icon name="whatsapp" class="h-4 w-4 shrink-0 text-[#25D366]" />
        WhatsApp {PHONE}
      </a>
    </div>

  </aside>
</div>

<div class="h-16"></div>

<script>
  // ── Scroll-aware bg ────────────────────────────────────────
  const header = document.getElementById('site-header');
  const bg = header?.querySelector<HTMLElement>('.header-bg');
  function updateBg() {
    if (!bg) return;
    if (window.scrollY > 12) {
      bg.classList.add('bg-surface-900/80', 'backdrop-blur-xl', 'border-white/10');
      bg.classList.remove('border-transparent');
    } else {
      bg.classList.remove('bg-surface-900/80', 'backdrop-blur-xl', 'border-white/10');
      bg.classList.add('border-transparent');
    }
  }
  window.addEventListener('scroll', updateBg, { passive: true });
  updateBg();

  // ── Drawer ─────────────────────────────────────────────────
  const toggle   = document.getElementById('mobile-toggle');
  const drawer   = document.getElementById('mobile-drawer');
  const backdrop = drawer?.querySelector<HTMLElement>('.drawer-backdrop');
  const panel    = drawer?.querySelector<HTMLElement>('.drawer-panel');
  const iconOpen  = toggle?.querySelector<HTMLElement>('.menu-open');
  const iconClose = toggle?.querySelector<HTMLElement>('.menu-close');

  function openDrawer() {
    if (!drawer || !panel || !backdrop) return;
    drawer.setAttribute('aria-hidden', 'false');
    drawer.classList.remove('pointer-events-none');
    backdrop.classList.add('opacity-100');
    panel.classList.remove('translate-x-full');
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    if (!drawer || !panel || !backdrop) return;
    drawer.setAttribute('aria-hidden', 'true');
    drawer.classList.add('pointer-events-none');
    backdrop.classList.remove('opacity-100');
    panel.classList.add('translate-x-full');
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () =>
    drawer?.getAttribute('aria-hidden') === 'true' ? openDrawer() : closeDrawer()
  );
  backdrop?.addEventListener('click', closeDrawer);
  panel?.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) =>
    a.addEventListener('click', closeDrawer)
  );
  panel?.querySelectorAll<HTMLElement>('.drawer-close').forEach((b) =>
    b.addEventListener('click', closeDrawer)
  );
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });
</script>
