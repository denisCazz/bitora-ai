---
import Icon from './ui/Icon.astro';

const services = [
  { label: "Automazioni AI", href: "/automazioni" },
  { label: "Chatbot Aziendale", href: "/chatbot" },
  { label: "Siti Web AI-ready", href: "/siti-web" },
  { label: "Gestionali con AI", href: "/gestionali" },
  { label: "Formazione AI", href: "/formazione" },
];

const resources = [
  { label: "Casi studio", href: "/casi-studio" },
  { label: "Bitora AI in Piemonte", href: "/piemonte" },
  { label: "Diagnosi gratuita", href: "/contatti" },
  { label: "Sito Bitora", href: "https://bitora.it", external: true },
];
---

<footer class="relative mt-32 border-t border-white/5">
  <!-- Gradient bar top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-500/50 to-transparent"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-1/2 bg-aurora-gradient blur-sm"></div>

  <!-- Big background mark -->
  <div class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-brand-500 to-transparent opacity-60"></div>
  <div class="pointer-events-none absolute -bottom-32 left-1/2 -translate-x-1/2 h-[300px] w-[800px] bg-brand-500/8 blur-4xl rounded-full"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">

      <!-- Brand col -->
      <div class="col-span-2 md:col-span-1 space-y-5">
        <div class="flex items-center gap-2.5">
          <div class="relative flex h-9 w-9 items-center justify-center rounded-xl bg-brand-gradient shadow-glow-soft">
            <svg class="h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l7 4v8l-7 4-7-4V6z"/>
              <path d="M12 2v16M5 6l7 4 7-4"/>
            </svg>
          </div>
          <div class="flex flex-col leading-none">
            <span class="text-sm font-bold text-white font-display">Bitora <span class="text-accent-400">AI</span></span>
            <span class="text-[10px] text-slate-400">by bitora.it</span>
          </div>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed">
          AI operativa per PMI e aziende del territorio. Partiamo dai tuoi processi reali, non dalle promesse.
        </p>
        <div class="flex items-center gap-3">
          <a href="https://bitora.it" target="_blank" rel="noopener" aria-label="Bitora" class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 hover:border-brand-500/40 transition-colors text-slate-400 hover:text-white">
            <Icon name="globe" class="h-4 w-4" />
          </a>
          <a href="https://wa.me/393514979670" target="_blank" rel="noopener" aria-label="WhatsApp" class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-white/5 hover:bg-green-500/10 hover:border-green-500/40 transition-colors text-slate-400 hover:text-green-300">
            <Icon name="whatsapp" class="h-4 w-4" />
          </a>
          <a href="mailto:info@bitora.it" aria-label="Email" class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 hover:border-brand-500/40 transition-colors text-slate-400 hover:text-white">
            <Icon name="mail" class="h-4 w-4" />
          </a>
        </div>
      </div>

      <!-- Services col -->
      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500 mb-5">Soluzioni</h4>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a href={s.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources col -->
      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500 mb-5">Risorse</h4>
        <ul class="space-y-3">
          {resources.map((r) => (
            <li>
              <a
                href={r.href}
                target={r.external ? '_blank' : undefined}
                rel={r.external ? 'noopener' : undefined}
                class="text-sm text-slate-400 hover:text-white transition-colors"
              >
                {r.label}{r.external ? ' →' : ''}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact col -->
      <div class="col-span-2 md:col-span-1">
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500 mb-5">Contatti</h4>
        <p class="text-sm text-slate-400 leading-relaxed mb-4">
          Sede a Carmagnola (TO)<br />Serviamo tutta Italia
        </p>
        <a
          href="/contatti"
          class="inline-flex items-center gap-2 rounded-xl border border-brand-500/40 bg-brand-500/10 px-4 py-2.5 text-sm font-semibold text-brand-300 hover:bg-brand-500/20 hover:border-brand-500/60 transition-all"
        >
          Prenota diagnosi gratuita
          <Icon name="arrow" class="h-3.5 w-3.5" />
        </a>
      </div>

    </div>

    <div class="mt-14 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500">
        © {new Date().getFullYear()} Bitora · ai.bitora.it · P.IVA e condizioni su{' '}
        <a href="https://bitora.it/privacy-policy" target="_blank" rel="noopener" class="hover:text-slate-300 transition-colors">bitora.it</a>
      </p>
      <div class="flex items-center gap-5 text-xs text-slate-500">
        <a href="https://bitora.it/privacy-policy" target="_blank" rel="noopener" class="hover:text-slate-300 transition-colors">Privacy</a>
        <a href="https://bitora.it/cookie-policy" target="_blank" rel="noopener" class="hover:text-slate-300 transition-colors">Cookie</a>
        <span class="text-slate-700">·</span>
        <span class="font-mono text-[10px] tracking-wider text-slate-600">v2.0 · made in Piemonte</span>
      </div>
    </div>

  </div>
</footer>
