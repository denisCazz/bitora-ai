---
import Icon from './ui/Icon.astro';

const PHONE = "3514979670";
const WA_URL = `https://wa.me/39${PHONE}`;

const services = [
  { label: "Automazioni AI",    href: "/automazioni" },
  { label: "Chatbot Aziendale", href: "/chatbot"     },
  { label: "Siti Web AI-ready", href: "/siti-web"    },
  { label: "Gestionali con AI", href: "/gestionali"  },
  { label: "Formazione AI",     href: "/formazione"  },
];

const resources = [
  { label: "Casi studio",           href: "/casi-studio"         },
  { label: "Bitora AI in Piemonte", href: "/piemonte"            },
  { label: "Diagnosi gratuita",     href: "/contatti"            },
  { label: "Sito Bitora",           href: "https://bitora.it", external: true },
];
---

<footer class="relative mt-16 sm:mt-24 border-t border-white/5 overflow-hidden">
  <!-- Top gradient lines -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-500/50 to-transparent pointer-events-none"></div>
  <div class="pointer-events-none absolute -bottom-24 left-1/2 -translate-x-1/2 h-[260px] w-[700px] bg-brand-500/10 blur-4xl rounded-full"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16">

    <!-- ── Brand strip (always full-width on mobile) ──────── -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 pb-10 border-b border-white/5">

      <!-- Logo + tagline -->
      <div class="flex flex-col gap-4 max-w-xs">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/icona.png" alt="Bitora AI" width="36" height="36" class="h-9 w-9 rounded-xl shadow-glow-soft" />
          <div class="flex flex-col leading-none">
            <span class="text-sm font-bold text-white font-display">Bitora <span class="text-accent-400">AI</span></span>
            <span class="text-[10px] text-slate-400">by bitora.it</span>
          </div>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed">
          AI operativa per PMI e aziende del territorio. Partiamo dai tuoi processi reali, non dalle promesse.
        </p>
      </div>

      <!-- Contact shortcuts -->
      <div class="flex flex-col gap-3">
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 text-sm text-slate-300 hover:text-white transition-colors"
        >
          <span class="flex h-8 w-8 items-center justify-center rounded-lg border border-white/10 bg-white/5 hover:bg-green-500/10 hover:border-green-500/30 transition-colors text-[#25D366]">
            <Icon name="whatsapp" class="h-4 w-4" />
          </span>
          {PHONE}
        </a>
        <a
          href="mailto:info@bitora.it"
          class="inline-flex items-center gap-2.5 text-sm text-slate-400 hover:text-white transition-colors"
        >
          <span class="flex h-8 w-8 items-center justify-center rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 transition-colors">
            <Icon name="mail" class="h-4 w-4" />
          </span>
          info@bitora.it
        </a>
        <a
          href="https://bitora.it"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 text-sm text-slate-400 hover:text-white transition-colors"
        >
          <span class="flex h-8 w-8 items-center justify-center rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 transition-colors">
            <Icon name="globe" class="h-4 w-4" />
          </span>
          bitora.it
        </a>
      </div>
    </div>

    <!-- ── Nav links grid ───────────────────────────────────── -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 py-10">

      <!-- Soluzioni -->
      <div>
        <h4 class="text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-500 mb-4">Soluzioni</h4>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a href={s.href} class="text-sm text-slate-400 hover:text-white transition-colors leading-snug">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Risorse -->
      <div>
        <h4 class="text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-500 mb-4">Risorse</h4>
        <ul class="space-y-3">
          {resources.map((r) => (
            <li>
              <a
                href={r.href}
                target={r.external ? '_blank' : undefined}
                rel={r.external ? 'noopener noreferrer' : undefined}
                class="text-sm text-slate-400 hover:text-white transition-colors leading-snug"
              >
                {r.label}{r.external ? ' →' : ''}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA -->
      <div class="col-span-2 sm:col-span-1">
        <h4 class="text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-500 mb-4">Inizia ora</h4>
        <a
          href="/contatti"
          class="inline-flex items-center gap-2 rounded-xl border border-brand-500/40 bg-brand-500/10 px-4 py-2.5 text-sm font-semibold text-brand-300 hover:bg-brand-500/20 hover:border-brand-500/60 transition-all"
        >
          Diagnosi gratuita
          <Icon name="arrow" class="h-3.5 w-3.5" />
        </a>
        <p class="mt-3 text-xs text-slate-500 leading-relaxed">
          Sede a Carmagnola (TO)<br />Serviamo tutta Italia
        </p>
      </div>
    </div>

    <!-- ── Bottom bar ───────────────────────────────────────── -->
    <div class="pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-slate-500 text-center sm:text-left">
        © {new Date().getFullYear()} Bitora · ai.bitora.it · P.IVA su{' '}
        <a href="https://bitora.it/privacy-policy" target="_blank" rel="noopener noreferrer" class="hover:text-slate-300 transition-colors">bitora.it</a>
      </p>
      <div class="flex items-center gap-4 text-xs text-slate-500">
        <a href="https://bitora.it/privacy-policy" target="_blank" rel="noopener noreferrer" class="hover:text-slate-300 transition-colors">Privacy</a>
        <a href="https://bitora.it/cookie-policy" target="_blank" rel="noopener noreferrer" class="hover:text-slate-300 transition-colors">Cookie</a>
        <span class="font-mono text-[10px] text-slate-600">made in Piemonte</span>
      </div>
    </div>

  </div>
</footer>
