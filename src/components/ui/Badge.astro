---
interface Props {
  variant?: 'brand' | 'accent' | 'electric' | 'neutral';
  dot?: boolean;
  pulse?: boolean;
  class?: string;
}

const {
  variant = 'brand',
  dot = true,
  pulse = true,
  class: className = '',
} = Astro.props;

const variantMap = {
  brand: 'border-brand-500/30 bg-brand-500/10 text-brand-300',
  accent: 'border-accent-500/30 bg-accent-500/10 text-accent-300',
  electric: 'border-electric-400/40 bg-electric-400/10 text-electric-300',
  neutral: 'border-white/10 bg-white/5 text-slate-300',
};

const dotColorMap = {
  brand: 'bg-brand-400',
  accent: 'bg-accent-400',
  electric: 'bg-electric-400',
  neutral: 'bg-slate-400',
};
---

<span class={`inline-flex items-center gap-2 rounded-full border ${variantMap[variant]} px-3.5 py-1.5 text-[11px] font-medium tracking-wide backdrop-blur-sm ${className}`}>
  {dot && (
    <span class="relative flex h-1.5 w-1.5">
      {pulse && <span class={`absolute inline-flex h-full w-full rounded-full ${dotColorMap[variant]} opacity-75 animate-ping`}></span>}
      <span class={`relative inline-flex h-1.5 w-1.5 rounded-full ${dotColorMap[variant]}`}></span>
    </span>
  )}
  <slot />
</span>
