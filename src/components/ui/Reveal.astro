---
interface Props {
  delay?: number;
  as?: 'div' | 'span' | 'li' | 'section' | 'article';
  class?: string;
}
const { delay = 0, as = 'div', class: className = '' } = Astro.props;
const Tag = as as any;
---

<Tag class={`reveal ${className}`} style={`--reveal-delay:${delay}ms`}>
  <slot />
</Tag>

<script>
  const items = document.querySelectorAll<HTMLElement>('.reveal');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('reveal-in');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
  items.forEach((el) => obs.observe(el));
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.34,1.2,0.64,1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }
  .reveal.reveal-in {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>
