---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  external?: boolean;
  class?: string;
  id?: string;
  disabled?: boolean;
  ariaLabel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  external = false,
  class: className = '',
  id,
  disabled = false,
  ariaLabel,
} = Astro.props;

const base = 'group relative inline-flex items-center justify-center gap-2 font-semibold rounded-xl transition-all duration-200 ease-spring whitespace-nowrap select-none disabled:opacity-50 disabled:cursor-not-allowed';

const sizeMap = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};

const variantMap = {
  primary:
    'text-white bg-brand-gradient shadow-glow-soft hover:shadow-glow-brand hover:-translate-y-0.5 active:translate-y-0',
  secondary:
    'text-slate-100 bg-white/5 border border-white/10 backdrop-blur-md hover:bg-white/10 hover:border-white/20',
  ghost:
    'text-slate-300 hover:text-white hover:bg-white/5',
  outline:
    'text-brand-300 border border-brand-500/40 bg-brand-500/5 hover:bg-brand-500/15 hover:border-brand-500/60',
};

const cls = `${base} ${sizeMap[size]} ${variantMap[variant]} ${className}`;
const externalProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{href ? (
  <a href={href} id={id} class={cls} aria-label={ariaLabel} {...externalProps}>
    {variant === 'primary' && (
      <span class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity bg-[linear-gradient(135deg,#22d3ee,#6366f1)]"></span>
    )}
    <span class="relative z-10 flex items-center gap-2">
      <slot />
    </span>
  </a>
) : (
  <button type={type} id={id} class={cls} disabled={disabled} aria-label={ariaLabel}>
    {variant === 'primary' && (
      <span class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity bg-[linear-gradient(135deg,#22d3ee,#6366f1)]"></span>
    )}
    <span class="relative z-10 flex items-center gap-2">
      <slot />
    </span>
  </button>
)}
