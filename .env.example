# ──────────────────────────────────────────────
# ai.bitora.it · variabili d'ambiente
# ──────────────────────────────────────────────

# Resend · invio form contatti (https://resend.com/api-keys)
# Senza questa chiave il form salva i dati nei log ma NON invia email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email mittente (deve essere un dominio verificato su Resend)
CONTACT_FROM=no-reply@ai.bitora.it

# Email destinatario (chi riceve i lead)
CONTACT_TO=info@bitora.it

# (Opzionale) Override host/porta per Astro Node SSR
# HOST=0.0.0.0
# PORT=4321
